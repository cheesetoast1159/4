import { useState, useEffect, useRef, useCallback } from "react";

const LANES = 4;
const LANE_KEYS = ["D", "F", "J", "K"];
const LANE_COLORS = ["#FF4D4D", "#FFD700", "#4DFF91", "#4DA6FF"];
const HIT_ZONE_Y = 82; // percent from top
const TILE_HEIGHT = 80; // px
const BASE_SPEED = 180; // px/s
const SPEED_INCREMENT = 30; // px/s every 5s

export default function RhythmGame() {
  const [tiles, setTiles] = useState([]);
  const [score, setScore] = useState(0);
  const [combo, setCombo] = useState(0);
  const [maxCombo, setMaxCombo] = useState(0);
  const [speed, setSpeed] = useState(BASE_SPEED);
  const [effects, setEffects] = useState([]);
  const [gameStarted, setGameStarted] = useState(false);
  const [gameOver, setGameOver] = useState(false);
  const [laneFlash, setLaneFlash] = useState([false, false, false, false]);
  const [speedLevel, setSpeedLevel] = useState(1);

  const gameRef = useRef(null);
  const animFrameRef = useRef(null);
  const lastTimeRef = useRef(null);
  const tilesRef = useRef([]);
  const scoreRef = useRef(0);
  const comboRef = useRef(0);
  const maxComboRef = useRef(0);
  const speedRef = useRef(BASE_SPEED);
  const spawnTimerRef = useRef(0);
  const speedTimerRef = useRef(0);
  const idRef = useRef(0);
  const gameOverRef = useRef(false);
  const speedLevelRef = useRef(1);

  const addEffect = useCallback((lane, type) => {
    const id = Date.now() + Math.random();
    setEffects(prev => [...prev, { id, lane, type }]);
    setTimeout(() => setEffects(prev => prev.filter(e => e.id !== id)), 600);
  }, []);

  const flashLane = useCallback((lane) => {
    setLaneFlash(prev => {
      const next = [...prev];
      next[lane] = true;
      return next;
    });
    setTimeout(() => {
      setLaneFlash(prev => {
        const next = [...prev];
        next[lane] = false;
        return next;
      });
    }, 100);
  }, []);

  const getSpawnInterval = useCallback((spd) => {
    return Math.max(300, 700 - (spd - BASE_SPEED) * 2);
  }, []);

  const gameLoop = useCallback((timestamp) => {
    if (gameOverRef.current) return;
    if (!lastTimeRef.current) lastTimeRef.current = timestamp;
    const delta = (timestamp - lastTimeRef.current) / 1000;
    lastTimeRef.current = timestamp;

    // Speed up every 5 seconds
    speedTimerRef.current += delta * 1000;
    if (speedTimerRef.current >= 5000) {
      speedTimerRef.current = 0;
      speedRef.current += SPEED_INCREMENT;
      speedLevelRef.current += 1;
      setSpeed(speedRef.current);
      setSpeedLevel(speedLevelRef.current);
    }

    // Spawn tiles
    spawnTimerRef.current += delta * 1000;
    const spawnInterval = getSpawnInterval(speedRef.current);
    if (spawnTimerRef.current >= spawnInterval) {
      spawnTimerRef.current = 0;
      const lane = Math.floor(Math.random() * LANES);
      const newTile = { id: idRef.current++, lane, y: -TILE_HEIGHT };
      tilesRef.current = [...tilesRef.current, newTile];
    }

    // Move tiles
    const containerHeight = gameRef.current?.clientHeight || 600;
    const hitZonePx = (HIT_ZONE_Y / 100) * containerHeight;

    tilesRef.current = tilesRef.current.map(t => ({
      ...t,
      y: t.y + speedRef.current * delta,
    }));

    // Check missed tiles (past hit zone by more than TILE_HEIGHT)
    const missed = tilesRef.current.filter(t => t.y > hitZonePx + TILE_HEIGHT * 1.5);
    if (missed.length > 0) {
      gameOverRef.current = true;
      setGameOver(true);
      setMaxCombo(maxComboRef.current);
      return;
    }

    setTiles([...tilesRef.current]);
    animFrameRef.current = requestAnimationFrame(gameLoop);
  }, [getSpawnInterval]);

  const startGame = useCallback(() => {
    tilesRef.current = [];
    scoreRef.current = 0;
    comboRef.current = 0;
    maxComboRef.current = 0;
    speedRef.current = BASE_SPEED;
    speedLevelRef.current = 1;
    spawnTimerRef.current = 0;
    speedTimerRef.current = 0;
    lastTimeRef.current = null;
    gameOverRef.current = false;
    idRef.current = 0;

    setTiles([]);
    setScore(0);
    setCombo(0);
    setMaxCombo(0);
    setSpeed(BASE_SPEED);
    setSpeedLevel(1);
    setEffects([]);
    setGameOver(false);
    setGameStarted(true);

    animFrameRef.current = requestAnimationFrame(gameLoop);
  }, [gameLoop]);

  const handleKey = useCallback((lane) => {
    if (!gameStarted || gameOverRef.current) return;
    flashLane(lane);

    const containerHeight = gameRef.current?.clientHeight || 600;
    const hitZonePx = (HIT_ZONE_Y / 100) * containerHeight;
    const hitWindow = 55;

    const idx = tilesRef.current.findIndex(
      t => t.lane === lane && Math.abs(t.y - hitZonePx) < hitWindow
    );

    if (idx !== -1) {
      const diff = Math.abs(tilesRef.current[idx].y - hitZonePx);
      const isPerfect = diff < 20;
      tilesRef.current = tilesRef.current.filter((_, i) => i !== idx);
      comboRef.current += 1;
      if (comboRef.current > maxComboRef.current) maxComboRef.current = comboRef.current;
      const points = isPerfect ? 100 * comboRef.current : 50 * comboRef.current;
      scoreRef.current += points;
      setScore(scoreRef.current);
      setCombo(comboRef.current);
      addEffect(lane, isPerfect ? "PERFECT" : "GOOD");
    } else {
      comboRef.current = 0;
      setCombo(0);
      addEffect(lane, "MISS");
    }
  }, [gameStarted, flashLane, addEffect]);

  useEffect(() => {
    const onKey = (e) => {
      const map = { d: 0, f: 1, j: 2, k: 3 };
      const lane = map[e.key.toLowerCase()];
      if (lane !== undefined) handleKey(lane);
    };
    window.addEventListener("keydown", onKey);
    return () => window.removeEventListener("keydown", onKey);
  }, [handleKey]);

  useEffect(() => {
    return () => {
      if (animFrameRef.current) cancelAnimationFrame(animFrameRef.current);
    };
  }, []);

  const containerHeight = 600;

  return (
    <div style={{
      minHeight: "100vh",
      background: "#0a0a0a",
      display: "flex",
      flexDirection: "column",
      alignItems: "center",
      justifyContent: "center",
      fontFamily: "'Courier New', monospace",
      userSelect: "none",
    }}>
      {/* Title */}
      <div style={{ color: "#fff", fontSize: 28, fontWeight: 900, letterSpacing: 8, marginBottom: 12, textTransform: "uppercase" }}>
        RHYTHM<span style={{ color: "#FFD700" }}>STRIKE</span>
      </div>

      {/* HUD */}
      <div style={{ display: "flex", gap: 40, marginBottom: 10, color: "#fff", fontSize: 14, letterSpacing: 2 }}>
        <span>SCORE <span style={{ color: "#FFD700", fontWeight: 700 }}>{score}</span></span>
        <span>COMBO <span style={{ color: "#4DFF91", fontWeight: 700 }}>x{combo}</span></span>
        <span>SPD <span style={{ color: "#FF4D4D", fontWeight: 700 }}>LV{speedLevel}</span></span>
      </div>

      {/* Game Area */}
      <div ref={gameRef} style={{
        position: "relative",
        width: 320,
        height: containerHeight,
        background: "#111",
        border: "2px solid #333",
        overflow: "hidden",
        display: "flex",
      }}>
        {/* Lane dividers */}
        {[1, 2, 3].map(i => (
          <div key={i} style={{
            position: "absolute",
            left: `${(i / LANES) * 100}%`,
            top: 0,
            bottom: 0,
            width: 1,
            background: "#222",
            zIndex: 1,
          }} />
        ))}

        {/* Lane backgrounds (flash on press) */}
        {LANE_COLORS.map((color, i) => (
          <div key={i} style={{
            position: "absolute",
            left: `${(i / LANES) * 100}%`,
            width: `${100 / LANES}%`,
            top: 0,
            bottom: 0,
            background: laneFlash[i] ? color + "22" : "transparent",
            transition: "background 0.05s",
            zIndex: 0,
          }} />
        ))}

        {/* Hit zone line */}
        <div style={{
          position: "absolute",
          top: `${HIT_ZONE_Y}%`,
          left: 0,
          right: 0,
          height: 3,
          background: "#fff",
          zIndex: 3,
          boxShadow: "0 0 8px #fff",
        }} />

        {/* Hit zone targets */}
        {LANE_COLORS.map((color, i) => (
          <div key={i} style={{
            position: "absolute",
            left: `${(i / LANES) * 100 + 2}%`,
            width: `${100 / LANES - 4}%`,
            top: `calc(${HIT_ZONE_Y}% - 18px)`,
            height: 36,
            border: `2px solid ${color}`,
            background: color + "15",
            zIndex: 4,
            display: "flex",
            alignItems: "center",
            justifyContent: "center",
            fontSize: 11,
            color: color,
            fontWeight: 700,
            letterSpacing: 1,
          }}>
            {LANE_KEYS[i]}
          </div>
        ))}

        {/* Tiles */}
        {tiles.map(tile => (
          <div key={tile.id} style={{
            position: "absolute",
            left: `${(tile.lane / LANES) * 100 + 2}%`,
            width: `${100 / LANES - 4}%`,
            top: tile.y,
            height: TILE_HEIGHT,
            background: LANE_COLORS[tile.lane],
            zIndex: 2,
            borderRadius: 4,
            boxShadow: `0 0 10px ${LANE_COLORS[tile.lane]}88`,
          }} />
        ))}

        {/* Hit effects */}
        {effects.map(ef => (
          <div key={ef.id} style={{
            position: "absolute",
            left: `${(ef.lane / LANES) * 100}%`,
            width: `${100 / LANES}%`,
            top: `${HIT_ZONE_Y - 8}%`,
            zIndex: 10,
            textAlign: "center",
            fontSize: 13,
            fontWeight: 900,
            letterSpacing: 1,
            color: ef.type === "PERFECT" ? "#FFD700" : ef.type === "GOOD" ? "#4DFF91" : "#FF4D4D",
            animation: "floatUp 0.6s ease-out forwards",
            pointerEvents: "none",
          }}>
            {ef.type}
          </div>
        ))}

        {/* Overlay screens */}
        {!gameStarted && !gameOver && (
          <div style={{
            position: "absolute", inset: 0, background: "#000c",
            display: "flex", flexDirection: "column",
            alignItems: "center", justifyContent: "center", zIndex: 20, gap: 16,
          }}>
            <div style={{ color: "#fff", fontSize: 20, fontWeight: 900, letterSpacing: 4 }}>READY?</div>
            <div style={{ color: "#888", fontSize: 12, letterSpacing: 2 }}>USE D F J K KEYS</div>
            <div style={{ color: "#888", fontSize: 11, letterSpacing: 1 }}>SPEED INCREASES EVERY 5s</div>
            <button onClick={startGame} style={{
              marginTop: 8, padding: "10px 28px",
              background: "#FFD700", color: "#000",
              border: "none", fontWeight: 900, fontSize: 14,
              letterSpacing: 3, cursor: "pointer", fontFamily: "inherit",
            }}>START</button>
          </div>
        )}

        {gameOver && (
          <div style={{
            position: "absolute", inset: 0, background: "#000d",
            display: "flex", flexDirection: "column",
            alignItems: "center", justifyContent: "center", zIndex: 20, gap: 10,
          }}>
            <div style={{ color: "#FF4D4D", fontSize: 22, fontWeight: 900, letterSpacing: 4 }}>GAME OVER</div>
            <div style={{ color: "#fff", fontSize: 14, letterSpacing: 2 }}>SCORE: <span style={{ color: "#FFD700" }}>{score}</span></div>
            <div style={{ color: "#fff", fontSize: 14, letterSpacing: 2 }}>MAX COMBO: <span style={{ color: "#4DFF91" }}>x{maxCombo}</span></span></div>
            <div style={{ color: "#fff", fontSize: 14, letterSpacing: 2 }}>MAX SPEED: <span style={{ color: "#FF4D4D" }}>LV{speedLevel}</span></div>
            <button onClick={startGame} style={{
              marginTop: 10, padding: "10px 28px",
              background: "#FF4D4D", color: "#fff",
              border: "none", fontWeight: 900, fontSize: 14,
              letterSpacing: 3, cursor: "pointer", fontFamily: "inherit",
            }}>RETRY</button>
          </div>
        )}
      </div>

      {/* Mobile buttons */}
      <div style={{ display: "flex", gap: 6, marginTop: 14 }}>
        {LANE_KEYS.map((key, i) => (
          <button key={i} onPointerDown={() => handleKey(i)} style={{
            width: 72, height: 52,
            background: laneFlash[i] ? LANE_COLORS[i] : "#1a1a1a",
            color: LANE_COLORS[i],
            border: `2px solid ${LANE_COLORS[i]}`,
            fontFamily: "inherit",
            fontWeight: 900,
            fontSize: 18,
            cursor: "pointer",
            transition: "background 0.05s",
            letterSpacing: 1,
          }}>{key}</button>
        ))}
      </div>

      <style>{`
        @keyframes floatUp {
          0% { opacity: 1; transform: translateY(0) scale(1.2); }
          100% { opacity: 0; transform: translateY(-40px) scale(0.9); }
        }
      `}</style>
    </div>
  );
}
